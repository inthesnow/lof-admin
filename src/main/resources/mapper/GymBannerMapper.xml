<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.linkfit.admin.mapper.GymBannerMapper">

    <resultMap id="gymBannerResultMap" type="GymBanner">
        <id     property="id"         column="id"/>
        <result property="imageUrl"   column="image_url"/>
        <result property="title"      column="title"/>
        <result property="isActive"   column="is_active"/>
        <result property="sortOrder"  column="sort_order"/>
        <result property="createdAt"  column="created_at"/>
    </resultMap>

    <select id="findAll" resultMap="gymBannerResultMap">
        SELECT * FROM gym_banner ORDER BY sort_order ASC, created_at DESC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO gym_banner (image_url, title, is_active, sort_order)
        VALUES (#{imageUrl}, #{title}, 1,
            COALESCE((SELECT MAX(sort_order) + 1 FROM gym_banner b2), 0))
    </insert>

    <delete id="delete">
        DELETE FROM gym_banner WHERE id = #{id}
    </delete>

    <update id="updateSortOrder">
        UPDATE gym_banner SET sort_order = #{sortOrder} WHERE id = #{id}
    </update>

    <update id="toggleActive">
        UPDATE gym_banner SET is_active = #{isActive} WHERE id = #{id}
    </update>

</mapper>
