<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.linkfit.admin.mapper.GymHolidayMapper">

    <resultMap id="gymHolidayResultMap" type="GymHoliday">
        <id     property="id"          column="id"/>
        <result property="holidayDate" column="holiday_date"/>
        <result property="type"        column="type"/>
        <result property="name"        column="name"/>
        <result property="createdAt"   column="created_at"/>
    </resultMap>

    <select id="findAll" resultMap="gymHolidayResultMap">
        SELECT * FROM gym_holiday
        WHERE YEAR(holiday_date) = #{year}
        ORDER BY holiday_date ASC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO gym_holiday (holiday_date, type, name)
        VALUES (#{holidayDate}, #{type}, #{name})
        ON DUPLICATE KEY UPDATE name = #{name}
    </insert>

    <delete id="delete">
        DELETE FROM gym_holiday WHERE id = #{id}
    </delete>

</mapper>
