<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.linkfit.admin.mapper.OnepointRequestMapper">

    <resultMap id="opResultMap" type="com.linkfit.admin.domain.OnepointRequest">
        <id     property="id"             column="id"/>
        <result property="memberId"       column="member_id"/>
        <result property="memberName"     column="member_name"/>
        <result property="trainerId"      column="trainer_id"/>
        <result property="trainerName"    column="trainer_name"/>
        <result property="preferredDates" column="preferred_dates"/>
        <result property="bodyParts"      column="body_parts"/>
        <result property="hasPain"        column="has_pain"/>
        <result property="notes"          column="notes"/>
        <result property="status"         column="status"/>
        <result property="selectedDate"   column="selected_date"/>
        <result property="selectedTime"   column="selected_time"/>
        <result property="note"           column="note"/>
        <result property="createdAt"      column="created_at"/>
    </resultMap>

    <select id="findAll" resultMap="opResultMap">
        SELECT op.id, op.member_id, op.trainer_id,
               op.preferred_dates, op.body_parts, op.has_pain, op.notes,
               op.status, op.selected_date, op.selected_time, op.note,
               op.created_at,
               mp.name AS member_name,
               tp.name AS trainer_name
        FROM onepoint_requests op
        LEFT JOIN user_profiles mp ON op.member_id  = mp.user_id
        LEFT JOIN user_profiles tp ON op.trainer_id = tp.user_id
        <where>
            <if test="status != null and status != ''">AND op.status = #{status}</if>
        </where>
        ORDER BY op.created_at DESC
        LIMIT #{size} OFFSET #{offset}
    </select>

    <select id="count" resultType="long">
        SELECT COUNT(*) FROM onepoint_requests
        <where>
            <if test="status != null and status != ''">AND status = #{status}</if>
        </where>
    </select>

    <update id="updateStatus">
        UPDATE onepoint_requests
        SET status = #{status}, note = #{note}
        WHERE id = #{id}
    </update>

</mapper>
