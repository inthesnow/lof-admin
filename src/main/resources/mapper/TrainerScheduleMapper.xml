<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.linkfit.admin.mapper.TrainerScheduleMapper">

    <resultMap id="scheduleResultMap" type="com.linkfit.admin.domain.TrainerSchedule">
        <id     property="id"           column="id"/>
        <result property="type"         column="type"/>
        <result property="scheduleDate" column="schedule_date"/>
        <result property="startTime"    column="start_time"/>
        <result property="endTime"      column="end_time"/>
        <result property="memo"         column="memo"/>
        <result property="trainerId"    column="trainer_id"/>
        <result property="memberId"     column="member_id"/>
        <result property="trainerName"  column="trainer_name"/>
        <result property="memberName"   column="member_name"/>
        <result property="createdAt"    column="created_at"/>
    </resultMap>

    <sql id="scheduleSelect">
        SELECT ts.id, ts.type, ts.schedule_date, ts.start_time, ts.end_time,
               ts.memo, ts.trainer_id, ts.member_id, ts.created_at,
               tp.name AS trainer_name,
               mp.name AS member_name
        FROM trainer_schedules ts
        LEFT JOIN user_profiles tp ON ts.trainer_id = tp.user_id
        LEFT JOIN user_profiles mp ON ts.member_id  = mp.user_id
    </sql>

    <select id="findByMonth" resultMap="scheduleResultMap">
        <include refid="scheduleSelect"/>
        WHERE YEAR(ts.schedule_date) = #{year}
          AND MONTH(ts.schedule_date) = #{month}
        ORDER BY ts.schedule_date ASC, ts.start_time ASC
    </select>

    <select id="findByDate" resultMap="scheduleResultMap">
        <include refid="scheduleSelect"/>
        WHERE ts.schedule_date = #{date}
        ORDER BY ts.start_time ASC
    </select>

    <!-- 트레이너 개인 스케줄 조회 (캘린더 대신 목록으로 확인) -->
    <select id="findByTrainer" resultMap="scheduleResultMap">
        <include refid="scheduleSelect"/>
        WHERE ts.trainer_id = #{trainerId}
        <if test="fromDate != null and fromDate != ''">
            AND ts.schedule_date &gt;= #{fromDate}
        </if>
        <if test="toDate != null and toDate != ''">
            AND ts.schedule_date &lt;= #{toDate}
        </if>
        ORDER BY ts.schedule_date ASC, ts.start_time ASC
    </select>

</mapper>
