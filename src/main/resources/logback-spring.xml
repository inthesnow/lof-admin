<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ──────────────────────────────────────────────────────────────────
         LINK_Fit Admin  ·  Logback 설정
         - 활성 로그  : ./logs/lof-admin.log
         - 일별 로테이트 : ./logs/lof-admin.log-YYYYMMDD.gz  (매일 00:00)
         - ERROR 전용 : ./logs/lof-admin-error.log  (동기, 유실 없음)
         - 보관 기간  : 30일 / 총 용량 상한 1 GB
    ─────────────────────────────────────────────────────────────────── -->

    <property name="LOG_DIR"  value="./logs"/>
    <property name="LOG_FILE" value="${LOG_DIR}/lof-admin.log"/>

    <!-- 콘솔 패턴 (ANSI 색상 포함) -->
    <property name="CONSOLE_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %highlight(%-5level) [%15.15thread] %cyan(%-40.40logger{39}) : %msg%n%ex"/>

    <!-- 파일 패턴 (ANSI 제거 — grep 용이, 스택트레이스 포함) -->
    <property name="FILE_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%15.15thread] %-40.40logger{39} : %msg%n%ex"/>


    <!-- ── 1. Console Appender ──────────────────────────────────────── -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>


    <!-- ── 2. Rolling File Appender (INFO+, 비동기 래핑용 기반) ──────── -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_FILE}</file>
        <encoder>
            <pattern>${FILE_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- 매일 00:00 → lof-admin.log-YYYYMMDD.gz 압축 보관 -->
            <fileNamePattern>${LOG_DIR}/lof-admin.log-%d{yyyyMMdd}.gz</fileNamePattern>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>
    </appender>


    <!-- ── 3. ERROR 전용 동기 Appender (유실 방지) ──────────────────── -->
    <!--
        AsyncAppender 는 프로세스가 갑자기 종료될 때 버퍼 내용이 유실될 수 있음.
        ERROR/WARN 은 동기 appender 에 별도 기록하여 반드시 디스크에 남김.
    -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/lof-admin-error.log</file>
        <!-- ERROR/WARN 만 기록 -->
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>WARN</level>
        </filter>
        <encoder>
            <pattern>${FILE_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/lof-admin-error.log-%d{yyyyMMdd}.gz</fileNamePattern>
            <maxHistory>90</maxHistory>
            <totalSizeCap>500MB</totalSizeCap>
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>
        <!-- immediateFlush=true: 쓰기 즉시 디스크에 반영 (기본값이지만 명시) -->
        <immediateFlush>true</immediateFlush>
    </appender>


    <!-- ── 4. 비동기 파일 Appender (INFO 레벨 일반 로그용) ──────────── -->
    <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <discardingThreshold>0</discardingThreshold>
        <queueSize>512</queueSize>
        <maxFlushTime>5000</maxFlushTime>
        <includeCallerData>false</includeCallerData>
        <appender-ref ref="FILE"/>
    </appender>


    <!-- ── 5. 프로필별 Logger 설정 ──────────────────────────────────── -->

    <!-- dev: 콘솔 + 파일 (DEBUG) -->
    <springProfile name="dev">
        <!-- HTTP 요청/응답 로거 (RequestLoggingFilter) -->
        <logger name="ACCESS" level="INFO" additivity="false">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_FILE"/>
        </logger>

        <logger name="com.linkfit.admin" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </logger>
        <logger name="com.linkfit.admin.mapper" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_FILE"/>
        </logger>
        <logger name="org.mybatis" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>
        <logger name="org.springframework.security" level="INFO" additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </root>
    </springProfile>


    <!-- prod: 파일만 (INFO), ERROR는 동기 별도 파일 병행 -->
    <springProfile name="prod">
        <!-- HTTP 요청/응답 로거 (RequestLoggingFilter) -->
        <logger name="ACCESS" level="INFO" additivity="false">
            <appender-ref ref="ASYNC_FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </logger>

        <!-- 어드민 애플리케이션 로그: INFO → 비동기, WARN+ → 동기 동시 기록 -->
        <logger name="com.linkfit.admin" level="INFO" additivity="false">
            <appender-ref ref="ASYNC_FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </logger>

        <!-- Spring/MyBatis/Apache: WARN 이상만 동기 파일에 기록 -->
        <logger name="org.springframework"          level="WARN" additivity="false">
            <appender-ref ref="ERROR_FILE"/>
        </logger>
        <logger name="org.springframework.security" level="WARN" additivity="false">
            <appender-ref ref="ERROR_FILE"/>
        </logger>
        <logger name="org.mybatis" level="WARN" additivity="false">
            <appender-ref ref="ERROR_FILE"/>
        </logger>
        <logger name="org.apache"  level="WARN" additivity="false">
            <appender-ref ref="ERROR_FILE"/>
        </logger>

        <root level="WARN">
            <appender-ref ref="ERROR_FILE"/>
        </root>
    </springProfile>

</configuration>
