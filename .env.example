# LINK_Fit Admin — 운영 서버 환경 변수
# cp .env.example .env 후 실제 값으로 채우세요

# DB
DB_URL=jdbc:mariadb://localhost:3306/linkfit?allowMultiQueries=true&characterEncoding=UTF-8&serverTimezone=Asia/Seoul
DB_USERNAME=linkfit
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=your_jwt_secret_here_minimum_32_characters
JWT_EXPIRATION_MS=86400000

# CORS (쉼표로 여러 origin 허용, 기본값: https://admin.linkonfit.co.kr)
CORS_ALLOWED_ORIGINS=https://admin.linkonfit.co.kr
